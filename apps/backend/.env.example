# ========================================
# Peemail 后端环境变量模板
# 复制为 .env 并填写真实值
# ========================================

# 数据库
DATABASE_URL=postgresql://peemail:peemail@localhost:5432/peemail

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRES_IN=30d

# 服务端口
PORT=3000

# CORS（开发时可设为 *，生产环境改为具体域名）
CORS_ORIGIN=*

# 举报自动隐藏阈值（默认 3）
REPORT_HIDE_THRESHOLD=3

# Mapbox（用于服务端地理计算，可选）
MAPBOX_TOKEN=

# 推送通知（Phase 2）
EXPO_ACCESS_TOKEN=
